rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Trivia packs are read-only for authenticated players
    // Served via CDN for performance
    match /packs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin uploads only
    }
    
    // User specific assets (future use: avatars, custom backgrounds)
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
