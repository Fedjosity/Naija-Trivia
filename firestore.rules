rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User profile: owner OR admin can access
    match /users/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      
      match /completedPacks/{packId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if false;
      }
    }
    
    // Trivia packs: readable by all auth users, writeable ONLY by admin
    match /packs/{packId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Skins (Boutique): readable by all auth users, writeable ONLY by admin
    match /skins/{skinId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Leaderboards: global read access, admin can moderate
    match /leaderboards/{node=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
