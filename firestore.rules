rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User profile: owner can read and write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      // Completed packs: owner can read their own history
      match /completedPacks/{packId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Cloud Functions use Admin SDK to write
      }
    }
    
    // Trivia packs: authenticated users browse the catalog
    match /packs/{packId} {
      allow read: if request.auth != null;
      allow write: if false; // Published via Admin Dashboard
    }
    
    // Leaderboards: global read access for competition
    match /leaderboards/{node=**} {
      allow read: if request.auth != null;
      allow write: if false; // Sharded updates handled server-side
    }
  }
}
