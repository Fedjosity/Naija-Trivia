rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Global Access Rule for Admins
    // If a user is an admin, they have read/write access to everything.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Collection-Specific Rules (for non-admins)
    
    // User profile: owner access
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
      
      match /completedPacks/{packId} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }
    }
    
    // Public/Auth Reading: Allow all authenticated users to read core game data
    match /packs/{packId} {
      allow read: if request.auth != null;
    }

    match /skins/{skinId} {
      allow read: if request.auth != null;
    }

    match /boutiqueItems/{itemId} {
      allow read: if request.auth != null;
    }
    
    match /activities/{id} {
      allow read: if request.auth != null;
    }
  }
}
